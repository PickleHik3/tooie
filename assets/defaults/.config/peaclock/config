# -----------------------------------------------------------------------------
# Dimensions & Geometry
# -----------------------------------------------------------------------------
# FORCE block 2 1 to prevent squishing
block 2 1
margin 0 0
padding 0 0
date-padding 1

# -----------------------------------------------------------------------------
# Visual Texture
# -----------------------------------------------------------------------------
# Active: Solid block
fill-active ' '

# Inactive: The dots.
fill-inactive '·'

# Colon: Standard colon character for a lighter look
fill-colon ':'

# -----------------------------------------------------------------------------
# Toggles
# -----------------------------------------------------------------------------
set hour-24 off
set seconds off
set date on

# Keep OFF to maintain aspect ratio
set auto-size off
set auto-ratio off

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
locale ''
timezone ''
date '%A %B %d. %Y'
mode clock
view digital

# -----------------------------------------------------------------------------
# Styles: "Void Mint" Palette
# -----------------------------------------------------------------------------

# 1. BACKGROUND (Removed)
# Setting this to 'clear' removes the colored box entirely.
# The clock will now float on your terminal background.
style background clear

# 2. INACTIVE DOTS
# Background is clear (no blocks behind dots).
# Foreground is a Deep Emerald Green. Distinct, but fades into the back.
style inactive-bg clear
style inactive-fg #284a44

# 3. ACTIVE DIGITS (Seafoam)
# A crisp, modern Mint/Seafoam green. 
# Highly visible against dark transparent terminals.
style active-bg #73daca
style active-fg clear

# 4. THE COLON
# Matches the active digits for consistency.
style colon-fg #73daca
style colon-bg clear

# 5. THE DATE (Peach)
# A warm Peach/Gold.
# This creates a pleasing "Cold Time / Warm Date" contrast.
style date #ffbc90

# 6. UI ELEMENTS
style text #565f89
style prompt #73daca
style success #9ece6a
style error #db4b4b


