#!/usr/bin/env sh
set -eu

[ -n "${TMUX:-}" ] || exit 0

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
title="$(tmux show-option -gqv '@tooie-cheatsheet-title' 2>/dev/null || true)"
[ -n "$title" ] || title="    Keybinds    "
client_w="$(tmux display-message -p '#{client_width}')"
client_h="$(tmux display-message -p '#{client_height}')"
width=$((client_w - 2))
height=18
pos_x="C"
pos_y="C"

[ "$width" -gt 90 ] && width=90
[ "$width" -lt 56 ] && width=56
if [ "$height" -gt $((client_h - 2)) ]; then
  height=$((client_h - 2))
fi
[ "$height" -lt 14 ] && height=14

tmux display-popup \
  -E \
  -x "$pos_x" \
  -y "$pos_y" \
  -w "$width" \
  -h "$height" \
  -T "$title" \
  "TOOIE_CHEATSHEET_WIDTH=$width TOOIE_CHEATSHEET_HEIGHT=$height $SCRIPT_DIR/show-cheatsheet-view"
